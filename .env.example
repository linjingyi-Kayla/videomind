DEEPSEEK_API_KEY=sk-your-key-here
# 可选：模型名（DeepSeek OpenAI-compat）
DEEPSEEK_MODEL=deepseek-chat

# 可选：SQLite 文件路径（默认 data/videomind.sqlite3）
VIDEOMIND_DB_PATH=data/videomind.sqlite3

# 可选：生产数据库（Railway Postgres 等），优先于 VIDEOMIND_DB_PATH
# 例如：DATABASE_URL="postgresql+psycopg://user:pass@host:5432/dbname"
DATABASE_URL=

# 可选：RapidAPI 字幕服务密钥（用于获取 YouTube 字幕，绕开云 IP 封锁）
# 例如：RAPIDAPI_KEY="xxx"
RAPIDAPI_KEY=
## Claude / Anthropic
# 二选一即可
ANTHROPIC_API_KEY=your_key_here
# CLAUDE_API_KEY=your_key_here

# 可选：覆盖默认模型
# CLAUDE_MODEL=claude-3-5-sonnet-latest

# 可选：Web Push（PWA 通知）使用的 VAPID keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:videomind@example.com
