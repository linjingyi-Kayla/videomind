DEEPSEEK_API_KEY=sk-your-key-here
# 可选：模型名（DeepSeek OpenAI-compat）
DEEPSEEK_MODEL=deepseek-chat

# 可选：SQLite 文件路径（默认 data/videomind.sqlite3）
VIDEOMIND_DB_PATH=data/videomind.sqlite3

# 可选：RapidAPI 字幕服务密钥（用于获取 YouTube 字幕，绕开云 IP 封锁）
# 例如：RAPIDAPI_KEY="xxx"
RAPIDAPI_KEY=
## Claude / Anthropic
# 二选一即可
ANTHROPIC_API_KEY=your_key_here
# CLAUDE_API_KEY=your_key_here

# 可选：覆盖默认模型
# CLAUDE_MODEL=claude-3-5-sonnet-latest
